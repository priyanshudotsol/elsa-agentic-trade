OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# twitterapi.io
TWITTERAPI_IO_KEY=

# Optional override for the Twitter search string (default: BTC-focused query)
# TWITTER_SEARCH_TOPIC=

# `npm run dev` loops forever (default: every 300s). One shot: npm run dev:once or RUN_ONCE=1
# AGENT_LOOP_INTERVAL_MS=300000
# RUN_ONCE=1

# HTTP API (agent/server.ts). If 5000 is busy: PORT=5001 and start Vite with API_PROXY=http://localhost:5001
PORT=5000

# Polymarket / Polygon — real CLOB orders when dry-run is off
POLYMARKET_DRY_RUN=true
POLYMARKET_TRADE_USD=5
POLYGON_PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com

# Optional: fix a specific Gamma event slug for BTC 5m (otherwise auto slot)
# POLYMARKET_BTC_UP_DOWN_EVENT_SLUG=

# Elsa **trade decision** (BUY_YES / BUY_NO / SKIP): OpenAI via `agent/elsa/decision.ts` unless ELSA_DECISION_URL is set.
# To delegate to an external Elsa Workflows (or any) HTTP service:
# ELSA_DECISION_URL=http://localhost:5002/decide
# POST JSON: { sentiment, confidence, marketContext } → response: { marketJson: "<json string>" }

# polymarket/: prisma generate / migrate (dummy URL is OK for `pnpm exec prisma generate` only)
DATABASE_URL=postgresql://user:pass@localhost:5432/polymarket
DIRECT_DATABASE_URL=postgresql://user:pass@localhost:5432/polymarket
