{
  "name": "polymarket-trading-agent",
  "version": "1.0.0",
  "description": "TypeScript Polymarket agent: Twitter → OpenAI → optional CLOB (Polygon)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx index.ts",
    "dev:once": "tsx index.ts --once",
    "dev:server": "tsx agent/server.ts",
    "dev:all": "concurrently -k -n api,web -c blue,magenta \"npm run dev:server\" \"npm run dev --prefix web\"",
    "setup:polymarket": "cd polymarket && pnpm install && pnpm exec prisma generate && pnpm run build",
    "start:server": "node dist/agent/server.js",
    "run:once": "tsx index.ts --once"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
